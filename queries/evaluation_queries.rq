PREFIX ex: <http://example.org/f1#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# 1. All drivers
SELECT ?driver
WHERE {
  ?driver rdf:type ex:Driver .
}

# 2. All teams
SELECT ?team
WHERE {
  ?team rdf:type ex:Team .
}

# 3. Drivers in season 2024
SELECT ?driver
WHERE {
  ?driver ex:competesInSeason ex:Season2024 .
}

# 4. Verstappen standing in 2024
SELECT ?standing ?position ?points
WHERE {
  ?standing rdf:type ex:DriverStanding .
  ?standing ex:forDriver ex:MaxVerstappen .
  ?standing ex:forSeason ex:Season2024 .
  ?standing ex:standingPosition ?position .
  ?standing ex:standingPoints ?points .
}

# 5. Ferrari drivers
SELECT ?driver
WHERE {
  ?driver ex:drivesFor ex:Ferrari .
}