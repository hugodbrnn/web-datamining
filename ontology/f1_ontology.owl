@prefix ex:   <http://example.org/f1#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ─────────────────────────────────────────────
# ONTOLOGY
# ─────────────────────────────────────────────

ex:F1Ontology a owl:Ontology ;
    rdfs:label "Formula 1 Knowledge Graph Ontology"@en ;
    rdfs:comment "Protégé-compatible version of the F1 ontology. Schema is identical to f1_ontology.ttl. Individuals are illustrative examples only (not exhaustive)."@en .

# ─────────────────────────────────────────────
# CLASSES
# ─────────────────────────────────────────────

ex:Driver a owl:Class ;
    rdfs:label "Driver"@en .

ex:Team a owl:Class ;
    rdfs:label "Team"@en .

ex:Season a owl:Class ;
    rdfs:label "Season"@en .

ex:GrandPrix a owl:Class ;
    rdfs:label "Grand Prix"@en .

ex:Circuit a owl:Class ;
    rdfs:label "Circuit"@en .

ex:RaceResult a owl:Class ;
    rdfs:label "Race Result"@en .

ex:DriverStanding a owl:Class ;
    rdfs:label "Driver Standing"@en .

ex:TeamStanding a owl:Class ;
    rdfs:label "Team Standing"@en .

# ─────────────────────────────────────────────
# OBJECT PROPERTIES
# ─────────────────────────────────────────────

ex:drivesFor a owl:ObjectProperty ;
    rdfs:domain ex:Driver ;
    rdfs:range  ex:Team ;
    rdfs:label  "drives for"@en .

ex:teammateOf a owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:domain ex:Driver ;
    rdfs:range  ex:Driver ;
    rdfs:label  "teammate of"@en .

ex:competesInSeason a owl:ObjectProperty ;
    rdfs:domain ex:Driver ;
    rdfs:range  ex:Season ;
    rdfs:label  "competes in season"@en .

ex:hasRace a owl:ObjectProperty ;
    rdfs:domain ex:Season ;
    rdfs:range  ex:GrandPrix ;
    rdfs:label  "has race"@en .

ex:heldAtCircuit a owl:ObjectProperty ;
    rdfs:domain ex:GrandPrix ;
    rdfs:range  ex:Circuit ;
    rdfs:label  "held at circuit"@en .

ex:hasResult a owl:ObjectProperty ;
    rdfs:domain ex:GrandPrix ;
    rdfs:range  ex:RaceResult ;
    rdfs:label  "has result"@en .

ex:forDriver a owl:ObjectProperty ;
    rdfs:range  ex:Driver ;
    rdfs:label  "for driver"@en .

ex:forTeam a owl:ObjectProperty ;
    rdfs:domain ex:TeamStanding ;
    rdfs:range  ex:Team ;
    rdfs:label  "for team"@en .

ex:forSeason a owl:ObjectProperty ;
    rdfs:range  ex:Season ;
    rdfs:label  "for season"@en .

ex:forGrandPrix a owl:ObjectProperty ;
    rdfs:domain ex:RaceResult ;
    rdfs:range  ex:GrandPrix ;
    rdfs:label  "for Grand Prix"@en .

ex:hasStanding a owl:ObjectProperty ;
    rdfs:domain ex:Driver ;
    rdfs:range  ex:DriverStanding ;
    rdfs:label  "has standing"@en .

# ─────────────────────────────────────────────
# DATATYPE PROPERTIES
# ─────────────────────────────────────────────

ex:name a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:range xsd:string ;
    rdfs:label "name"@en .

ex:nationality a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "nationality"@en .

ex:seasonYear a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain ex:Season ;
    rdfs:range  xsd:int ;
    rdfs:label  "season year"@en .

ex:standingPosition a owl:DatatypeProperty ;
    rdfs:range xsd:int ;
    rdfs:label "standing position"@en .

ex:standingPoints a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "standing points"@en .

ex:finishPosition a owl:DatatypeProperty ;
    rdfs:domain ex:RaceResult ;
    rdfs:range  xsd:int ;
    rdfs:label  "finish position"@en .

ex:points a owl:DatatypeProperty ;
    rdfs:domain ex:RaceResult ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "points"@en .

# ─────────────────────────────────────────────
# INDIVIDUALS — SEASONS (rolling 5-season window)
# ─────────────────────────────────────────────

ex:Season2022 a ex:Season ;
    ex:name       "Formula 1 Season 2022" ;
    ex:seasonYear 2022 .

ex:Season2023 a ex:Season ;
    ex:name       "Formula 1 Season 2023" ;
    ex:seasonYear 2023 .

ex:Season2024 a ex:Season ;
    ex:name       "Formula 1 Season 2024" ;
    ex:seasonYear 2024 .

ex:Season2025 a ex:Season ;
    ex:name       "Formula 1 Season 2025" ;
    ex:seasonYear 2025 .

ex:Season2026 a ex:Season ;
    ex:name       "Formula 1 Season 2026" ;
    ex:seasonYear 2026 .

# ─────────────────────────────────────────────
# INDIVIDUALS — TEAMS (illustrative)
# ─────────────────────────────────────────────

ex:Mercedes a ex:Team ;
    ex:name "Mercedes" .

ex:RedBullRacing a ex:Team ;
    ex:name "Red Bull Racing" .

ex:Ferrari a ex:Team ;
    ex:name "Ferrari" .

ex:McLaren a ex:Team ;
    ex:name "McLaren" .

ex:AstonMartin a ex:Team ;
    ex:name "Aston Martin" .

# ─────────────────────────────────────────────
# INDIVIDUALS — DRIVERS (illustrative)
# ─────────────────────────────────────────────

ex:MaxVerstappen a ex:Driver ;
    ex:name        "Max Verstappen" ;
    ex:nationality "NED" ;
    ex:drivesFor   ex:RedBullRacing ;
    ex:competesInSeason
        ex:Season2022, ex:Season2023, ex:Season2024, ex:Season2025 .

ex:LewisHamilton a ex:Driver ;
    ex:name        "Lewis Hamilton" ;
    ex:nationality "GBR" ;
    ex:drivesFor   ex:Ferrari ;
    ex:competesInSeason
        ex:Season2022, ex:Season2023, ex:Season2024, ex:Season2025, ex:Season2026 .

ex:LandoNorris a ex:Driver ;
    ex:name        "Lando Norris" ;
    ex:nationality "GBR" ;
    ex:drivesFor   ex:McLaren ;
    ex:competesInSeason
        ex:Season2022, ex:Season2023, ex:Season2024, ex:Season2025, ex:Season2026 .

# ─────────────────────────────────────────────
# INDIVIDUALS — CIRCUITS (illustrative)
# ─────────────────────────────────────────────

ex:SilverstoneCircuit a ex:Circuit ;
    ex:name "Silverstone Circuit" .

ex:MonzaCircuit a ex:Circuit ;
    ex:name "Autodromo Nazionale Monza" .

ex:InterlagosCircuit a ex:Circuit ;
    ex:name "Autodromo Jose Carlos Pace" .
