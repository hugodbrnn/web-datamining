ex:MaxVerstappen a ex:Driver .
ex:CharlesLeclerc a ex:Driver .

########################
# SEASON
########################

ex:Season2023 a ex:Season .

########################
# RELATIONS
########################

# Drivers -> Teams
ex:LewisHamilton ex:drivesFor ex:Mercedes .
ex:MaxVerstappen ex:drivesFor ex:RedBullRacing .
ex:CharlesLeclerc ex:drivesFor ex:Ferrari .

# Drivers -> Season
ex:LewisHamilton ex:competesInSeason ex:Season2023 .
ex:MaxVerstappen ex:competesInSeason ex:Season2023 .
ex:CharlesLeclerc ex:competesInSeason ex:Season2023 .



########################
# GRAND PRIX
########################

