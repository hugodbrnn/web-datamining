    ex:hasStanding ex:Standing_2026_ArvidLindblad ;
    ex:name "Arvid Lindblad" ;
    ex:nationality "GBR" ;
    owl:sameAs wd:Q117035650 .

ex:Circuit a owl:Class ;
    rdfs:label "Circuit"@en ;
    rdfs:comment "A racing circuit that hosts a Grand Prix."@en .

