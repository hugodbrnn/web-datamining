ex:competesInSeason a owl:ObjectProperty ;
    rdfs:label "competes in season"@en ;
    rdfs:domain ex:Driver ;
    rdfs:range ex:Season .

ex:drivesFor a owl:ObjectProperty ;
    rdfs:label "drives for"@en ;
    rdfs:comment "Links a driver to their current or most recent team."@en ;
    rdfs:domain ex:Driver ;
    rdfs:range ex:Team .

ex:finishPosition a owl:DatatypeProperty ;
    rdfs:label "finish position"@en ;
    rdfs:domain ex:RaceResult ;
    rdfs:range xsd:int .

ex:forDriver a owl:ObjectProperty ;
    rdfs:label "for driver"@en ;
    rdfs:domain [ owl:unionOf ( ex:DriverStanding ex:RaceResult ) ] ;
    rdfs:range ex:Driver .

ex:forGrandPrix a owl:ObjectProperty ;
    rdfs:label "for Grand Prix"@en ;
    rdfs:domain ex:RaceResult ;
    rdfs:range ex:GrandPrix .

ex:forSeason a owl:ObjectProperty ;
    rdfs:label "for season"@en ;
    rdfs:domain [ owl:unionOf ( ex:DriverStanding ex:TeamStanding ) ] ;
    rdfs:range ex:Season .

ex:forTeam a owl:ObjectProperty ;
    rdfs:label "for team"@en ;
    rdfs:domain ex:TeamStanding ;
    rdfs:range ex:Team .

ex:hasRace a owl:ObjectProperty ;
    rdfs:label "has race"@en ;
    rdfs:domain ex:Season ;
    rdfs:range ex:GrandPrix .

ex:hasResult a owl:ObjectProperty ;
    rdfs:label "has result"@en ;
    rdfs:domain ex:GrandPrix ;
    rdfs:range ex:RaceResult .

ex:hasStanding a owl:ObjectProperty ;
    rdfs:label "has standing"@en ;
    rdfs:domain ex:Driver ;
    rdfs:range ex:DriverStanding .

ex:heldAtCircuit a owl:ObjectProperty ;
    rdfs:label "held at circuit"@en ;
    rdfs:domain ex:GrandPrix ;
    rdfs:range ex:Circuit .

ex:name a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:range xsd:string .

ex:nationality a owl:DatatypeProperty ;
    rdfs:label "nationality"@en ;
    rdfs:comment "ISO 3166-1 alpha-3 nationality code (e.g. GBR, NED, FRA)."@en ;
    rdfs:range xsd:string .

ex:points a owl:DatatypeProperty ;
    rdfs:label "points"@en ;
    rdfs:domain ex:RaceResult ;
    rdfs:range xsd:decimal .

ex:seasonYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "season year"@en ;
    rdfs:domain ex:Season ;
    rdfs:range xsd:int .

ex:standingPoints a owl:DatatypeProperty ;
    rdfs:label "standing points"@en ;
    rdfs:domain [ owl:unionOf ( ex:DriverStanding ex:TeamStanding ) ] ;
    rdfs:range xsd:decimal .

ex:standingPosition a owl:DatatypeProperty ;
    rdfs:label "standing position"@en ;
    rdfs:domain [ owl:unionOf ( ex:DriverStanding ex:TeamStanding ) ] ;
    rdfs:range xsd:int .

ex:teammateOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "teammate of"@en ;
    rdfs:domain ex:Driver ;
    rdfs:range ex:Driver .

